# --- MONGODB CONNECTION ---
# Replace with your actual MongoDB URI (local or Atlas)
MONGO_URI=mongodb://localhost:27017/version-control-db

# --- SERVER CONFIG ---
PORT=5000

# --- AUTHENTICATION ---
# Random string for signing JSON Web Tokens
JWT_SECRET=super_secret_jwt_key_12345

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- EMAIL (SMTP) ---
# Replace with your email provider's SMTP details
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
